# Sokoban Brawl - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database
SQLITE_PATH=data/sokoban.db

# GitHub Webhook (for auto-deployment)
# Generate a secure random string: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret_here

# Deployment Configuration
DEPLOY_BRANCH=main
# REPO_DIR=/opt/sokoban-brawl  # Optional: override auto-detected path
# LOG_FILE=/var/log/sokoban-brawl-deploy.log  # Optional: custom log location
